{
  "$schema": "https://raw.githubusercontent.com/encounter/objdiff/main/config.schema.json",
  "custom_make": "python",
  "custom_args": ["tools/build.py", "--skip-asm"],
  "build_target": false,
  "build_base": true,
  "watch_patterns": ["*.c", "*.h", "*.s", "*.inc"],
  "units": [
    {
      "name": "main",
      "target_path": "expected/src/main.c.o",
      "base_path": "build/src/main.c.o"
    }
  ]
}
